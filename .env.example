# Topgun AI — shared environment template
# Copy this file to .env (or use the per-app .env.example files directly).

# --- Backend (FastAPI) ---------------------------------------------------
TOPGUN_ENV=development
TOPGUN_LOG_LEVEL=info
TOPGUN_API_HOST=0.0.0.0
TOPGUN_API_PORT=8000
TOPGUN_CORS_ORIGINS=http://localhost:3000

# Demo mode seeds the backend from sample_data/ and does not require a DB.
TOPGUN_DEMO_MODE=true

# Future: Postgres + pgvector
DATABASE_URL=postgresql+psycopg://topgun:topgun@localhost:5432/topgun
VECTOR_BACKEND=memory   # memory | pgvector

# AI providers (all optional while TOPGUN_DEMO_MODE=true)
AI_PROVIDER=stub        # stub | openai | anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Embedding configuration
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Ingestion
INGESTION_UPLOAD_DIR=./storage/uploads
INGESTION_MAX_MB=50

# --- Frontend (Next.js) --------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Topgun AI
NEXT_PUBLIC_APP_TAGLINE=AI Maintenance Intelligence for Aviation Teams

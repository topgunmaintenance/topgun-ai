TOPGUN_ENV=development
TOPGUN_LOG_LEVEL=info
TOPGUN_API_HOST=0.0.0.0
TOPGUN_API_PORT=8000
TOPGUN_CORS_ORIGINS=http://localhost:3000
TOPGUN_DEMO_MODE=true

DATABASE_URL=postgresql+psycopg://topgun:topgun@localhost:5432/topgun
VECTOR_BACKEND=memory

AI_PROVIDER=stub
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

EMBEDDING_MODEL=text-embedding-3-small
